                default 0
                help
                    The initial weight of source1 audio stream.
                    The weight value maintained under stable conditions when MIXER is set to 'FADE_DOWNWARD' mode.

            config GMF_AUDIO_EFFECT_MIXER_SRC1_WEIGHT2
                int "Target Weight × 100 (e.g. 100 for 1.0)"
                range 0 100
                default 100
                help
                    The target weight of source1 audio stream.
                    The weight value maintained under stable conditions when MIXER is set to 'FADE_UPWARD' mode.

            config GMF_AUDIO_EFFECT_MIXER_SRC1_TRANSIT_TIME
                int "Transition Time (ms)"
                default 500
                range 0 10000
                help
                    Time of change from weight1 to weight2 or weight2 to weight1 for source1.
                    Unit: ms
        endmenu

