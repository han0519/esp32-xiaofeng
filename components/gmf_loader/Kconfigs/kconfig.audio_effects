        config GMF_EQ_FILTER_NUM
            int "Number of EQ Filters"
            range 0 10
            default 0
            help
                Number of EQ filters to configure
                Note:
                1) The actual number of EQ filters can exceed this range.
                   Users can modify the EQ configuration by calling `OBJ_GET_CFG` to get
                   the original EQ configuration structure.
                2) If set to 0, the default configuration `DEFAULT_ESP_GMF_EQ_CONFIG` will be used.

        menu "Filter1 Parameters"
            depends on GMF_EQ_FILTER_NUM >= 1
            visible if GMF_EQ_FILTER_NUM >= 1

            choice GMF_EQ_FILTER1_TYPE
                prompt "Filter Type"
                default ESP_AE_EQ_FILTER1_PEAK
                help
                    Configure the type of equalizer filter.

                config ESP_AE_EQ_FILTER1_HIGH_PASS
                    bool "High Pass"
                    help
                        High pass filter.

                config ESP_AE_EQ_FILTER1_LOW_PASS
                    bool "Low Pass"
                    help
                        Low pass filter.

                config ESP_AE_EQ_FILTER1_PEAK
                    bool "Peak"
                    help
                        Peak filter.

                config ESP_AE_EQ_FILTER1_HIGH_SHELF
                    bool "High Shelf"
                    help
                        High Shelf filter.

                config ESP_AE_EQ_FILTER1_LOW_SHELF
                    bool "Low Shelf"
                    help
                        Low Shelf filter.
            endchoice

            config GMF_EQ_FILTER1_TYPE
                int
                default 1 if ESP_AE_EQ_FILTER1_HIGH_PASS
                default 2 if ESP_AE_EQ_FILTER1_LOW_PASS
                default 3 if ESP_AE_EQ_FILTER1_PEAK
                default 4 if ESP_AE_EQ_FILTER1_HIGH_SHELF
                default 5 if ESP_AE_EQ_FILTER1_LOW_SHELF

            config GMF_EQ_FILTER1_FC
                int "Frequency (Hz)"
                default 1000
                help
                    The value should be less than half of the sampling rate.
                    For high shelf, low shelf, and peak filter, it represents the center frequency.
                    For high pass and low pass filter, it represents the cut-off frequency.

            config GMF_EQ_FILTER1_QX1000
                int "Q × 1000 (e.g. 1000 for Q=1.0)"
                range 100 20000
                default 1000
                help
                    Q value of filter. Used to describe the bandwidth of the filter.
                    The higher the Q value, the narrower the bandwidth,
                    the lower the Q value, the wider the bandwidth.

            config GMF_EQ_FILTER1_GAINX10
                int "Gain × 10 (e.g. -30 for -3.0 dB)"
                range -150 150
                default 0
                help
                    Gain value of filter.
                    Only valid for high shelf, low shelf, and peak filter.
        endmenu

